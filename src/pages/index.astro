---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main>
			<h1>Wren's Workshop</h1>
			<p class="tagline">Making things. Drawing things. Building things.</p>
			<p class="coming-soon">Site coming soon.</p>
		</main>

		<style>
			body {
				margin: 0;
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				background: #fdf6ec;
				color: #2b2b2b;
				font-family: 'Atkinson', sans-serif;
				text-align: center;
				padding: 1rem;
			}
			main {
				max-width: 32rem;
			}
			h1 {
				font-size: clamp(2.5rem, 8vw, 4rem);
				margin: 0 0 1rem;
				letter-spacing: -0.02em;
			}
			.tagline {
				font-size: 1.25rem;
				margin: 0 0 2rem;
			}
			.coming-soon {
				font-size: 0.95rem;
				opacity: 0.6;
				margin: 0;
			}
		</style>
	</body>
</html>
